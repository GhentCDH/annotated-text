{
  "name": "e2e",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "e2e",
  "tags": [],
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/playwright-report"],
      "options": {
        "commands": [
          "docker compose -f e2e/docker-compose.playwright.yml run --rm playwright"
        ],
        "cwd": "{workspaceRoot}"
      }
    },
    "e2e:ui": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "docker compose -f e2e/docker-compose.playwright.yml run --rm --service-ports playwright-ui"
        ],
        "cwd": "{workspaceRoot}"
      }
    },
    "e2e:local": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/playwright-report"],
      "options": {
        "command": "playwright test -c e2e/playwright.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "e2e:local:ui": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright test -c e2e/playwright.config.ts --ui",
        "cwd": "{workspaceRoot}"
      }
    },
    "e2e:update-snapshots": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "docker compose -f e2e/docker-compose.playwright.yml run --rm update-snapshots"
        ],
        "cwd": "{workspaceRoot}"
      }
    },
    "e2e:coverage": {
      "executor": "nx:run-commands",
      "outputs": ["libs/core/coverage/e2e"],
      "options": {
        "commands": [
          "docker compose -f e2e/docker-compose.playwright.yml run --rm playwright-coverage"
        ],
        "cwd": "{workspaceRoot}"
      }
    },
    "e2e:coverage:local": {
      "executor": "nx:run-commands",
      "outputs": ["libs/core/coverage/e2e"],
      "options": {
        "commands": [
          "COVERAGE=true playwright test -c e2e/playwright.config.ts",
          "npx nyc report --reporter=text --reporter=text-summary --reporter=html --reporter=lcov --reporter=json-summary"
        ],
        "cwd": "{workspaceRoot}",
        "parallel": false
      }
    }
  }
}
